{
  "name": "property-management-saas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.3",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "postinstall": "npx prisma generate --schema=packages/database/prisma/schema.prisma",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "firebase-tools": "^15.12.0",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "turbo": "latest"
  }
}
