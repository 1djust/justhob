generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id
  email               String               @unique
  name                String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  role                Role                 @default(PROPERTY_MANAGER)
  isActive            Boolean              @default(true)
  maintenanceMessages MaintenanceMessage[]
  notifications       Notification[]
  propertiesOwned     Property[]
  workspaces          WorkspaceMember[]
}

model Workspace {
  id                    String               @id @default(uuid())
  name                  String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  bankCode              String?
  accountNumber         String?
  accountName           String?
  plan                  SubscriptionPlan     @default(FREE)
  status                WorkspaceStatus      @default(ACTIVE)
  subscriptionExpiresAt DateTime?
  allowPartialPayments  Boolean              @default(true)
  maintenanceMessages   MaintenanceMessage[]
  maintenanceRequests   MaintenanceRequest[]
  payments              Payment[]
  properties            Property[]
  tenants               Tenant[]
  units                 Unit[]
  members               WorkspaceMember[]
}

model WorkspaceMember {
  id             String          @id @default(uuid())
  role           Role            @default(TENANT)
  userId         String
  workspaceId    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accountNumber  String?
  bankCode       String?
  payoutStrategy PayoutStrategy?
  accountName    String?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Property {
  id                  String               @id @default(uuid())
  name                String
  address             String
  workspaceId         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  ownerId             String?
  imageUrl            String?
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  owner               User?                @relation(fields: [ownerId], references: [id])
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  units               Unit[]

  @@unique([id, workspaceId], name: "property_workspace_id")
}

model Unit {
  id          String       @id @default(uuid())
  unitNumber  String
  type        PropertyType
  status      UnitStatus   @default(VACANT)
  propertyId  String
  workspaceId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  leases      Lease[]
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([propertyId, unitNumber])
  @@unique([id, workspaceId], name: "unit_workspace_id")
}

model Tenant {
  id                   String               @id @default(uuid())
  name                 String
  email                String?
  phone                String?
  workspaceId          String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  allowPartialPayments Boolean?
  leases               Lease[]
  maintenanceRequests  MaintenanceRequest[]
  workspace            Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], name: "tenant_workspace_id")
}

model Lease {
  id            String              @id @default(uuid())
  tenantId      String
  propertyId    String
  startDate     DateTime
  endDate       DateTime?
  yearlyRent    Float               @default(0) @map("monthlyRent")
  status        LeaseStatus         @default(ACTIVE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  unitId        String?
  property      Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit          Unit?               @relation(fields: [unitId], references: [id])
  renewalOffers LeaseRenewalOffer[]
  payments      Payment[]
}

model Payment {
  id                   String               @id @default(uuid())
  leaseId              String
  amount               Float
  dueDate              DateTime
  paidDate             DateTime?
  status               PaymentStatus        @default(PENDING)
  note                 String?
  rrr                  String?              @unique
  transactionId        String?              @unique
  paymentUrl           String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  proofUrl             String?
  receiptId            String?              @unique
  rejectionReason      String?
  workspaceId          String?
  amountPaid           Float?
  balanceNote          String?
  balancePromise       DateTime?
  gracePeriodEnd       DateTime?
  evictionNoticeSent   Boolean              @default(false)
  evictionDate         DateTime?
  paymentPlanRequested Boolean              @default(false)
  paymentPlanStatus    String?
  lease                Lease                @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  workspace            Workspace?           @relation(fields: [workspaceId], references: [id])
  transactions         PaymentTransaction[]
  reminders            RentReminder[]

  @@unique([id, workspaceId], name: "payment_workspace_id")
}

model PaymentTransaction {
  id        String   @id @default(uuid())
  paymentId String
  amount    Float
  status    String   @default("COMPLETED")
  note      String?
  receiptId String?  @unique
  proofUrl  String?
  paidDate  DateTime @default(now())
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String               @id @default(uuid())
  description String
  imageUrl    String?
  status      MaintenanceStatus    @default(PENDING)
  tenantId    String
  propertyId  String
  workspaceId String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  priority    MaintenancePriority  @default(MEDIUM)
  vendor      String?
  messages    MaintenanceMessage[]
  property    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], name: "maintenance_workspace_id")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ErrorLog {
  id        String   @id @default(uuid())
  level     String   @default("error")
  message   String
  stack     String?
  context   Json?
  source    String
  createdAt DateTime @default(now())
}

model MaintenanceMessage {
  id          String             @id @default(uuid())
  content     String
  requestId   String
  senderId    String?
  workspaceId String
  isRead      Boolean            @default(false)
  createdAt   DateTime           @default(now())
  type        String             @default("USER")
  request     MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User?              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RentReminder {
  id        String   @id @default(uuid())
  paymentId String
  type      String
  sentAt    DateTime @default(now())
  channel   String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model LeaseRenewalOffer {
  id           String    @id @default(uuid())
  leaseId      String
  newRent      Float
  newStartDate DateTime
  newEndDate   DateTime
  terms        String?
  status       String    @default("PENDING")
  sentAt       DateTime  @default(now())
  respondedAt  DateTime?
  lease        Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id        String   @id @default(uuid())
  source    String
  eventId   String   @unique
  payload   Json
  status    String   @default("PROCESSED")
  createdAt DateTime @default(now())
}

model SecurityAuditLog {
  id        String   @id @default(uuid())
  eventType String
  ipAddress String
  details   Json?
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([createdAt])
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum WorkspaceStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum PayoutStrategy {
  DIRECT_TO_LANDLORD
  MANAGER_COLLECTS
}

enum Role {
  PROPERTY_MANAGER
  LANDLORD
  TENANT
  SUPER_ADMIN
}

enum PropertyType {
  ROOM_SELF_CONTAIN
  MINI_FLAT
  ROOM_PARLOUR_SELF_CONTAIN
  SINGLE_ROOM
  TWO_BEDROOM_FLAT
  THREE_BEDROOM_FLAT
  DUPLEX
  OTHERS
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING_RENEWAL
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  UNDER_REVIEW
  PARTIALLY_PAID
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}
